# Copy this file to .env and fill in your values.
# Get client id/secret by creating an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must exactly match a Redirect URI registered on the Spotify app
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Filled in automatically by get_refresh_token.py after you run it once
SPOTIFY_REFRESH_TOKEN=

# Filled in automatically by get_refresh_token.py when it creates the playlist
SPOTIFY_PLAYLIST_ID=
